# Flask
FLASK_ENV=development
FLASK_DEBUG=false
SECRET_KEY=change-me
UPLOAD_DIR=uploads

# Database
# Local development fallback:
DATABASE_URL=sqlite:///cv_review.db
# Production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Redis for OTP and login rate limiting
REDIS_URL=redis://localhost:6379/0
MAX_OTP_REQUESTS=3
OTP_WINDOW_SECONDS=300
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_SECONDS=900
OTP_TTL_SECONDS=300

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=CV Reviewer <your_email@example.com>
APP_NAME=CV Reviewer

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
ALLOW_PUBLIC_URL_FALLBACK=false

# Optional AI rewrite provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
